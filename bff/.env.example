# NCR Voyix BSP Credentials
# Get these from the NCR Voyix developer portal
BSP_API_GATEWAY=https://api.ncr.com
BSP_ORGANIZATION=your-organization-id
BSP_SITE_ID=your-site-id
BSP_SHARED_KEY=your-shared-key
BSP_SECRET_KEY=your-secret-key

# BFF Server
BFF_PORT=8765
BFF_HOST=0.0.0.0
JWT_SECRET=change-this-to-a-strong-random-secret
# Comma-separated allowed origins in production (e.g. your Vercel URL).
# Leave unset to allow all origins (development only).
ALLOWED_ORIGINS=https://your-app.vercel.app

# Mobile (for Expo — prefix with EXPO_PUBLIC_)
EXPO_PUBLIC_BFF_URL=http://localhost:8765
